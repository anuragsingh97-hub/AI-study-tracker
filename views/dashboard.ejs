<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-light">

<%- include("partials/navbar") %>

<div class="container mt-4">

  <h3 class="mb-4">Your Study Dashboard</h3>

  <!-- Stats Cards -->
  <div class="row mb-4">
    <div class="col-md-4">
      <div class="card shadow text-center p-3" id="totalSessionsCard1">
        <h6>Total Sessions</h6>
        <h3><%= sessions.length %></h3>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow text-center p-3" id="totalSessionsCard2">
        <h6>Average Focus Score</h6>
        <h3>
          <%
            let avg = 0;
            if(sessions.length > 0){
              avg = sessions.reduce((sum,s)=>sum+s.focusScore,0)/sessions.length;
            }
          %>
          <%= avg.toFixed(1) %>%
        </h3>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow text-center p-3">
        <h6>Total Study Time</h6>
        <h3>
          <%= sessions.reduce((sum,s)=>sum+s.studyTime,0) %> mins
        </h3>
      </div>
    </div>
  </div>

  <!-- Chart -->
  <div class="card shadow p-4 mb-4" id="sessionHistory2">
    <h5>Focus Score Trend</h5>
    <canvas id="focusChart" height="500px"></canvas>
  </div>

  <!-- Session History -->
  <div class="card shadow p-4" id="sessionHistory">

    <h5 class="mb-3">Session History</h5>

    <div class="accordion" id="subjectAccordion">

    <% let i = 0; %>

    <% if(grouped){ %>
    <% for(let subject in grouped){ %>

      <div class="accordion-item">

        <h2 class="accordion-header">
          <button class="accordion-button collapsed"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#collapse<%= i %>">
            📚 <%= subject %> (<%= grouped[subject].length %> Sessions)
          </button>
        </h2>

        <div id="collapse<%= i %>" class="accordion-collapse collapse">
          <div class="accordion-body">

            <table class="table table-bordered text-center">
              <thead class="table-light">
                <tr>
                  <th>Study Time</th>
                  <th>Distraction</th>
                  <th>Focus %</th>
                </tr>
              </thead>

              <tbody>
                <% grouped[subject].forEach(s=>{ %>
                  <tr>
                    <td><%= s.studyTime %></td>
                    <td><%= s.distractionTime %></td>
                    <td><%= s.focusScore.toFixed(2) %>%</td>
                  </tr>
                <% }) %>
              </tbody>

            </table>

          </div>
        </div>

      </div>

    <% i++; %>
    <% } %>
    <% } %>

    </div>
  </div>

</div>

<!-- ✅ Chart Script (Separate) -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const labels = <%- JSON.stringify(sessions.map(s => new Date(s.date).toLocaleDateString())) %>;
  const data = <%- JSON.stringify(sessions.map(s => s.focusScore)) %>;

  const ctx = document.getElementById("focusChart");

  if (ctx && labels.length > 0) {
    new Chart(ctx, {
      type: "line",
      data: {
        labels: labels,
        datasets: [{
          label: "Focus Score",
          data: data,
          borderWidth: 2,
          tension: 0.3
        }]
      }
    });
  }

  // Scroll Features
  document.getElementById("totalSessionsCard1").addEventListener("click", function(){
    document.getElementById("sessionHistory").scrollIntoView({ behavior: "smooth" });
  });

  document.getElementById("totalSessionsCard2").addEventListener("click", function(){
    document.getElementById("sessionHistory2").scrollIntoView({ behavior: "smooth" });
  });

});
</script>

<!-- ✅ Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>